# ============================================================================
# EXCEPTIONS - Files to ALWAYS track
# ============================================================================
# These files should be committed despite matching patterns above
!.gitkeep
!.env.example
!backend/.env.example
!frontend/.env.example
!.github/
!.github/workflows/
!docs/
!README.md
!SETUP.md
!QUICK_START.md
!PROJECT_SUMMARY.md
!PROJECT_STRUCTURE.md
!IMPLEMENTATION_CHECKLIST.md
!FILES_CREATED.md
!DELIVERY_SUMMARY.txt
!ARCHITECTURE_DIAGRAM.txt
